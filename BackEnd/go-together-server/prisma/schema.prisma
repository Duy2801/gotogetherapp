generator client {
  provider      = "prisma-client"
  output        = "./generated"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
  moduleFormat  = "cjs"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  fullName          String?
  password          String?
  dateOfBirth       DateTime?
  gender            Int?
  status            UserStatus     @default(ACTIVE)
  isVerified        Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  googleId          String?        @unique
  avatar            String?
  sentNotifications Notification[] @relation("SentNotifications")
  notifications     Notification[]
  budgets           Budget[]
  celebrates        Celebrate[]
  celebrateComments CelebrateComment[]
  celebrateReactions CelebrateReaction[]
  devices           Device[]
  expenseSplits     ExpenseSplit[]
  expenses          Expense[]      @relation("PaidBy")
  tripMembers       TripMember[]
  userRoles         UserRole[]

  @@map("users")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String
  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String
  roles       RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId String
  roleId Int
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade, map: "user_roles_role_fkey")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId], map: "user_roles_roleId_fkey")
  @@map("user_roles")
}

model RolePermission {
  roleId       Int
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, map: "role_permissions_permission_fkey")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId], map: "role_permissions_permissionId_fkey")
  @@map("role_permissions")
}

model Trip {
  id          String       @id @default(uuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  totalBudget Decimal?     @db.Decimal(15, 2)
  status      TripStatus   @default(UPCOMING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  images      String?
  celebrates  Celebrate[]
  expenses    Expense[]
  itineraries Itinerary[]
  members     TripMember[]

  @@map("trips")
}

model TripMember {
  id           String       @id @default(uuid())
  tripId       String
  userId       String
  role         MemberRole   @default(MEMBER)
  inviteStatus InviteStatus @default(PENDING)
  joinedAt     DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  leftAt       DateTime?
  trip         Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade, map: "trip_members_user_fkey")

  @@unique([tripId, userId])
  @@index([userId], map: "trip_members_userId_fkey")
  @@map("trip_members")
}

model Category {
  id        String    @id @default(uuid())
  name      String
  icon      String?
  color     String?
  isDefault Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expenses  Expense[]

  @@map("categories")
}

model Expense {
  id          String         @id @default(uuid())
  tripId      String
  amount      Decimal        @db.Decimal(15, 2)
  currency    String         @default("VND")
  categoryId  String
  description String?
  paidById    String
  type        ExpenseType    @default(SHARED)
  date        DateTime       @default(now())
  receipt     String?
  isConfirmed Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  splits      ExpenseSplit[]
  category    Category       @relation(fields: [categoryId], references: [id], map: "expenses_category_fkey")
  paidBy      User           @relation("PaidBy", fields: [paidById], references: [id], map: "expenses_paidBy_fkey")
  trip        Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade, map: "expenses_trip_fkey")

  @@index([categoryId], map: "expenses_categoryId_fkey")
  @@index([paidById], map: "expenses_paidById_fkey")
  @@index([tripId], map: "expenses_tripId_fkey")
  @@map("expenses")
}

model ExpenseSplit {
  id          String    @id @default(uuid())
  expenseId   String
  userId      String
  amount      Decimal   @db.Decimal(15, 2)
  percentage  Decimal?  @db.Decimal(5, 2)
  splitType   SplitType @default(EQUAL)
  isPaid      Boolean   @default(false)
  paidAt      DateTime?
  confirmed   Boolean   @default(false)
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  expense     Expense   @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], map: "expense_splits_user_fkey")

  @@unique([expenseId, userId])
  @@index([userId], map: "expense_splits_userId_fkey")
  @@map("expense_splits")
}

model Budget {
  id        String   @id @default(uuid())
  userId    String
  amount    Decimal  @db.Decimal(15, 2)
  month     Int
  year      Int
  warningAt Int      @default(80)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@index([userId])
  @@map("budgets")
}

model Itinerary {
  id          String   @id @default(uuid())
  tripId      String
  date        DateTime
  title       String
  description String?
  activities  Json?
  photos      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade, map: "itineraries_trip_fkey")

  @@index([tripId], map: "itineraries_tripId_fkey")
  @@map("itineraries")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  refId     String?
  senderId  String?
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  sender    User?            @relation("SentNotifications", fields: [senderId], references: [id])
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refId])
  @@index([senderId])
}

model Device {
  id        Int      @id @default(autoincrement())
  deviceId  String
  fcmToken  String
  userId    String
  platform  String?
  locale    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("devices")
}

model Celebrate {
  id          String           @id @default(uuid())
  tripId      String
  userId      String
  description String?
  date        DateTime
  createdAt   DateTime         @default(now())
  images      CelebrateImage[]
  comments    CelebrateComment[]
  reactions   CelebrateReaction[]
  trip        Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("celebrates")
}

model CelebrateImage {
  id          String    @id @default(uuid())
  celebrateId String
  imageUrl    String
  createdAt   DateTime  @default(now())
  celebrate   Celebrate @relation(fields: [celebrateId], references: [id], onDelete: Cascade)

  @@index([celebrateId])
  @@map("celebrate_images")
}

model CelebrateComment {
  id          String    @id @default(uuid())
  celebrateId String
  userId      String
  content     String
  createdAt   DateTime  @default(now())

  celebrate   Celebrate  @relation(fields: [celebrateId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([celebrateId])
  @@index([userId])
  @@map("celebrate_comments")
}

model CelebrateReaction {
  id          String    @id @default(uuid())
  celebrateId String
  userId      String
  emoji       String
  createdAt   DateTime  @default(now())

  celebrate   Celebrate  @relation(fields: [celebrateId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([celebrateId, userId, emoji])
  @@index([celebrateId])
  @@index([userId])
  @@map("celebrate_reactions")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum TripStatus {
  UPCOMING
  ONGOING
  COMPLETED
  ARCHIVED
}

enum MemberRole {
  OWNER
  MEMBER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ExpenseType {
  SHARED
  PERSONAL
}

enum SplitType {
  EQUAL
  PERCENTAGE
  AMOUNT
}

enum NotificationType {
  TRIP_INVITE
  MEMBER_JOINED
  EXPENSE_CREATED
  BUDGET_WARNING
  SETTLEMENT_REMINDER
  EXPENSE_REMINDER
  PAYMENT_MARKED
  PAYMENT_CONFIRMED
  INVITATION_REJECTED
}
